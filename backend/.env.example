# TradeMentor AI Environment Configuration

PROJECT_NAME="TradeMentor AI"
ENVIRONMENT="development"

# Database (Required)
# Supabase format: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/tradementor"

# Supabase (Optional - for direct API access)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-service-key"

# Frontend URL (for OAuth redirect)
FRONTEND_URL="http://localhost:8080"

# Zerodha Kite Connect
ZERODHA_API_KEY=""
ZERODHA_API_SECRET=""
ZERODHA_REDIRECT_URI="http://localhost:8000/api/zerodha/callback"

# OpenRouter (for AI features)
OPENROUTER_API_KEY=""

# OpenAI (optional — used for embeddings/RAG features; not required for core AI coaching)
OPENAI_API_KEY=""

# WhatsApp — CURRENT provider: Twilio (set TWILIO_* to activate)
# Migration to Gupshup is pending Meta Business Manager + template approval.
# Gupshup vars are stored but NOT active yet — do NOT set only Gupshup vars
# or messages will be silently dropped. Use Twilio until migration is complete.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
TWILIO_PHONE_NUMBER=""

# Gupshup (future provider — pending Meta template approval)
GUPSHUP_API_KEY=""
GUPSHUP_APP_NAME=""
GUPSHUP_WHATSAPP_FROM=""
GUPSHUP_TMPL_REPORT=""
GUPSHUP_TMPL_ALERT=""
GUPSHUP_TMPL_GUARDIAN=""

# Redis (for Celery async tasks)
# Local: redis://localhost:6379/0
# Upstash: rediss://default:PASSWORD@HOST:PORT
REDIS_URL="redis://localhost:6379/0"

# Optional: Separate Celery broker URL (defaults to REDIS_URL)
# CELERY_BROKER_URL=""

# Admin panel JWT secret (Required for /admin/* to work — otherwise all admin routes return 404)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Must differ from SECRET_KEY. Keep separate so admin auth can be rotated independently.
ADMIN_JWT_SECRET="GENERATE_ME"
ADMIN_JWT_EXPIRE_HOURS=8

# Security (Required - app will not start without these)
# Generate ENCRYPTION_KEY with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️  NEVER change this key after users have connected — changing it makes ALL stored
#     Zerodha access tokens and API secrets undecryptable. Users must reconnect manually.
#     Back this key up securely (e.g., your password manager or secrets vault).
ENCRYPTION_KEY="GENERATE_ME"
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="GENERATE_ME"

# Token settings
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Web Push VAPID keys (for browser push notifications)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="admin@yourdomain.com"

# SMTP (for admin OTP email delivery — NOT used for user-facing emails)
# Leave blank to disable email. In dev: OTP is logged at WARNING level and stored in Redis.
# Retrieve dev OTP with: redis-cli GET admin_otp:<email>
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="TradeMentor Admin <noreply@yourdomain.com>"

# Sentry error tracking (create free project at sentry.io)
SENTRY_DSN=""

# Server port (used by Procfile / Heroku / Render)
PORT=8000

# Maintenance mode — set to true to return 503 with MAINTENANCE_MESSAGE for all API calls
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="We're performing scheduled maintenance. Back in a few minutes."

# CORS — space-separated list of allowed origins for production
# BACKEND_CORS_ORIGINS=["https://app.yourdomain.com"]
