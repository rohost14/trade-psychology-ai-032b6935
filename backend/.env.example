# TradeMentor AI Environment Configuration

PROJECT_NAME="TradeMentor AI"
ENVIRONMENT="development"

# Database (Required)
# Supabase format: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/tradementor"

# Supabase (Optional - for direct API access)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-service-key"

# Frontend URL (for OAuth redirect)
FRONTEND_URL="http://localhost:8080"

# Zerodha Kite Connect
ZERODHA_API_KEY=""
ZERODHA_API_SECRET=""
ZERODHA_REDIRECT_URI="http://localhost:8000/api/zerodha/callback"

# OpenRouter (for AI features)
OPENROUTER_API_KEY=""

# Twilio (for WhatsApp notifications)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
TWILIO_PHONE_NUMBER=""

# Redis (for Celery async tasks)
# Local: redis://localhost:6379/0
# Upstash: rediss://default:PASSWORD@HOST:PORT
REDIS_URL="redis://localhost:6379/0"

# Optional: Separate Celery broker URL (defaults to REDIS_URL)
# CELERY_BROKER_URL=""

# Security (Required - app will not start without these)
# Generate ENCRYPTION_KEY with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY="GENERATE_ME"
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="GENERATE_ME"

# Token settings
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
